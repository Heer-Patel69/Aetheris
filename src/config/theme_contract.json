{
  "theme": {
    "name": "Monochromatic Minimal Luxury",
    "version": "1.0.0",
    "colors": {
      "bg-core": "#0a0a0a",
      "bg-surface": "#121212",
      "bg-elevated": "#1a1a1a",
      "border-default": "#262626",
      "border-active": "#404040",
      "text-primary": "#f5f5f5",
      "text-secondary": "#a3a3a3",
      "text-muted": "#525252",
      "brand-accent": "#ffffff",
      "brand-subtle": "#e5e5e5",
      "success": "#a3e635",
      "warning": "#fbbf24",
      "error": "#f87171"
    },
    "typography": {
      "font-sans": "'Inter', 'Outfit', system-ui, sans-serif",
      "font-mono": "'SF Mono', 'Fira Code', monospace"
    },
    "spacing": {
      "density": "high",
      "padding-card": "1.5rem",
      "gap-default": "1rem"
    },
    "effects": {
      "shadow-soft": "0 4px 12px 0 rgba(0, 0, 0, 0.5)",
      "radius-default": "4px",
      "transition-default": "all 0.2s cubic-bezier(0.4, 0, 0.2, 1)"
    }
  }
}
