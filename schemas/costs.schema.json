{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CostsConfigSchema",
  "type": "object",
  "patternProperties": {
    "^[a-zA-Z0-9\\-_\\.]+$": {
      "type": "object",
      "properties": {
        "input_cost_1k": { "type": "number", "minimum": 0 },
        "output_cost_1k": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false,
      "required": ["input_cost_1k", "output_cost_1k"]
    }
  },
  "additionalProperties": false
}
