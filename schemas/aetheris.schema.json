{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BrainConfigSchema",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "environment": {
      "type": "string",
      "enum": ["production", "development", "test"],
      "default": "production"
    },
    "timeouts": {
      "type": "object",
      "properties": {
        "ingest": { "type": "integer", "minimum": 10, "default": 5000 },
        "discover": { "type": "integer", "minimum": 10, "default": 10000 },
        "plan": { "type": "integer", "minimum": 10, "default": 15000 },
        "route": { "type": "integer", "minimum": 10, "default": 5000 },
        "execute": { "type": "integer", "minimum": 10, "default": 60000 },
        "verify": { "type": "integer", "minimum": 10, "default": 30000 },
        "commit": { "type": "integer", "minimum": 10, "default": 10000 },
        "log": { "type": "integer", "minimum": 10, "default": 5000 }
      },
      "additionalProperties": false,
      "required": ["ingest", "discover", "plan", "route", "execute", "verify", "commit", "log"]
    },
    "limits": {
      "type": "object",
      "properties": {
        "max_retries_per_task": { "type": "integer", "minimum": 1, "maximum": 5, "default": 3 },
        "max_telemetry_dir_size_mb": { "type": "integer", "minimum": 10, "maximum": 5000, "default": 200 },
        "max_plugin_hook_execution_ms": { "type": "integer", "minimum": 10, "maximum": 5000, "default": 50 }
      },
      "additionalProperties": false,
      "required": ["max_retries_per_task", "max_telemetry_dir_size_mb", "max_plugin_hook_execution_ms"]
    },
    "paths": {
      "type": "object",
      "properties": {
        "global_runtime_dir": { "type": "string" },
        "global_config_dir": { "type": "string" },
        "global_log_dir": { "type": "string" },
        "global_plugin_dir": { "type": "string" }
      },
      "additionalProperties": false,
      "required": ["global_runtime_dir", "global_config_dir", "global_log_dir", "global_plugin_dir"]
    },
    "optimization": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "max_context_tokens": { "type": "integer", "minimum": 100, "default": 15000 },
        "cache_dir": { "type": "string" },
        "index_dir": { "type": "string" },
        "default_local_provider": { "type": "string", "default": "ollama" },
        "local_providers": {
          "type": "object",
          "properties": {
            "ollama": { "type": "string" },
            "lm_studio": { "type": "string" }
          },
          "additionalProperties": true
        },
        "model_specializations": {
          "type": "object",
          "properties": {
            "reasoning": { "type": "string" },
            "coding": { "type": "string" },
            "local": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false,
      "required": ["enabled", "max_context_tokens"]
    }
  },
  "additionalProperties": false,
  "required": ["version", "environment", "timeouts", "limits", "paths", "optimization"]
}